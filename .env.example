# Copy to .env and fill in. The CLI loads .env automatically (existing env wins).

# --- LLM provider (analyst + builder + judge) ---
# OpenAI or OpenAI-compatible endpoint:
OPENAI_API_KEY=sk-...
# Optional: custom base URL for an OpenAI-compatible gateway/proxy.
OPENAI_BASE_URL=https://api.openai.com/v1

# If using Anthropic instead, set this and configure PIPELINE_MODEL accordingly.
# ANTHROPIC_API_KEY=sk-ant-...

# --- Per-stage models ---
# Global default for every stage:
PIPELINE_MODEL=openai:gpt-5.4-mini
# Optional per-stage overrides (fall back to PIPELINE_MODEL when unset).
# Analyst and judge need vision; builder benefits from a strong coder;
# fix_build can be cheap (falls back to the builder model, then default).
# PIPELINE_MODEL_ANALYST=openai:claude-opus-4-8
# PIPELINE_MODEL_BUILDER=openai:claude-opus-4-8
# PIPELINE_MODEL_FIX_BUILD=openai:gpt-5.4-mini
# PIPELINE_MODEL_JUDGE=openai:claude-opus-4-8

# --- Deploy (Netlify) ---
# Required for the deploy stage; the deployer fails loudly if missing.
NETLIFY_AUTH_TOKEN=xxx

# --- Pipeline paths (CLI flags override these) ---
# Output project name (or pass --name):
# PIPELINE_NAME=mylanding
# Top directory (default: cwd):
# PIPELINE_TOP=..
# Instructions file and references directory:
# PIPELINE_INSTRUCTIONS=../input/instructions.md
# PIPELINE_REFERENCES_DIR=../input/references
# Runtime skills directory (default: <top>/.agents/skills):
# PIPELINE_SKILLS_DIR=.agents/skills
