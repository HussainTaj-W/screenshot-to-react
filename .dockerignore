# Keep the build context lean.
.venv/
# Never bake secrets into the image — pass .env at runtime (--env-file).
.env
.env.*
!.env.example
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.git/
node_modules/
dist/
.netlify/
debug_requests.jsonl
run.log
# Generated output projects are mounted at runtime, not baked in.
mylanding/
